<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.human-ai.daily-eval</string>

  <key>RunAtLoad</key>
  <false/>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>21</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <!-- 不再写死 4321:Tauri 壳用动态端口。gw-cron.sh 现场读 ~/.human-ai/.gateway-port。 -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/claudecodedezhuanshumac/.human-ai/bin/gw-cron.sh</string>
    <string>/api/eval/run</string>
    <string>{"model_id":"deepseek-v4-pro"}</string>
    <string>120</string>
  </array>

  <key>StandardOutPath</key>
  <string>/Users/claudecodedezhuanshumac/.human-ai/logs/daily-eval.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/claudecodedezhuanshumac/.human-ai/logs/daily-eval.err.log</string>
</dict>
</plist>
