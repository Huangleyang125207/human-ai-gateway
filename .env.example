# gateway secrets — 复制为 .env 后填值。
# .env 是 gitignore 的,永远不会上仓库。
# server.py 读优先级:os.environ > APP_STATE/config/.env > <gateway>/.env > gateway-config.json
# .env 覆盖 config.json 的对应字段,所以 secret 不必再放 config.json。

# ── 主对话 (DeepSeek 直连) — "说话的那个" ───────────────
# 去 platform.deepseek.com → API Keys 拿。每月赠 ¥10。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro

# ── 视觉助手 (阿里云百炼) — "给 deepseek 装眼睛" ─────────
# 去 bailian.console.aliyun.com → API-KEY 拿。新用户 token 福利。
# 即便不填 chat 也能跑(只是没 vision 自动分类 / 没 qwen-vl-ocr 长截图)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen3-vl-flash

# ── 可选:百度抠图(端侧 macOS Subject Lift 优先,百度只是 win/linux 兜底)─
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_CUTOUT_API_KEY=
BAIDU_CUTOUT_SECRET_KEY=

# ── 可选:Gemini Flash(基本废 — 百炼已含 qwen-vl)──────
GEMINI_API_KEY=
