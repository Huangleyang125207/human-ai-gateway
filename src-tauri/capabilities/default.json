{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:window:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "process:allow-exit",
    "allow-check-updates-now"
  ]
}
