{
  "name": "gateway-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway 移动端壳 — Capacitor 包现有 web 前端 + 本地 fetch-shim",
  "scripts": {
    "build:web": "bash ../build-web.sh",
    "sync": "npm run build:web && cap sync",
    "add:ios": "cap add ios",
    "add:android": "cap add android",
    "open:ios": "npm run sync && cap open ios",
    "open:android": "npm run sync && cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^6",
    "@capacitor/filesystem": "^6",
    "@capacitor/preferences": "^6",
    "capacitor-cutout": "file:../plugins/cutout"
  },
  "devDependencies": {
    "@capacitor/android": "^6",
    "@capacitor/cli": "^6",
    "@capacitor/ios": "^6"
  }
}
